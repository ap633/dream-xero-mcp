# Xero Custom Connection Credentials (from Xero Developer Portal)
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here

# Set to your Railway deployed URL + /callback
# (Not used for custom connections / client_credentials flow, but included for completeness)
XERO_REDIRECT_URI=https://dream-xero-mcp-production.up.railway.app/callback

# Railway sets this automatically — no need to set manually
PORT=3000
